# snow-white — InnovestX trading CLI config
# Copy to .env (gitignored) and fill in. Secrets must never be passed as CLI args.
# Loaded by viper (AutomaticEnv + .env). Env vars override .env.

# --- InnovestX API ---
# API key/secret from trade.innovestxonline.com -> Account -> API Keys.
# Scope the key to Read + Trading ONLY (no Withdraw). IP-whitelist it.
# The secret is shown only once at generation time — store it here securely.
INVX_APIKEY=
INVX_SECRET=

# API host. Use the dev host while testing; switch to prod for live trading.
#   dev : api-dev.innovestxonline.com
#   prod: api.innovestxonline.com
INVX_HOST=api-dev.innovestxonline.com

# --- Postgres ---
# Candle time-series + orders/positions/risk state.
PSQL_URL=postgres://user:pass@localhost:5432/snow_white?sslmode=disable
# Dev DB used by `task migrate-dev` (may equal PSQL_URL for local).
PSQL_DEV_URL=postgres://user:pass@localhost:5432/snow_white?sslmode=disable

# --- Collector defaults (overridable by flags) ---
INVX_SYMBOLS=BTCTHB,ETHTHB
INVX_COLLECT_INTERVAL=60s

# --- Trader risk caps (THB; overridable by flags) ---
# Trader runs in PAPER mode unless --live is passed.
INVX_MAX_ORDER=5000      # max THB per order
INVX_MAX_DAILY=50000     # max THB deployed per day
INVX_MAX_LOSS=10000      # daily realized-loss THB -> auto-halt
# Kill switch file: create this file to halt all trading instantly.
INVX_KILL_FILE=./.halt
